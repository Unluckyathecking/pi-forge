{
  "name": "pi-forge",
  "version": "1.0.0",
  "description": "Pi Forge — Proof-carrying, hexagonal-core, multi-level autonomous coding factory",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "pi-forge": "dist/cli/index.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "build:clean": "rm -rf dist && tsc",
    "watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run test",
    "start": "node dist/cli/index.js",
    "dev": "tsx src/cli/index.ts"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "zod": "^3.23.0",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/js-yaml": "^4.0.9",
    "@types/proper-lockfile": "^4.1.4",
    "typescript": "^5.4.0",
    "tsx": "^4.10.0",
    "jest": "^29.7.0",
    "@jest/globals": "^29.7.0",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.8.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0"
  },
  "keywords": [
    "pi",
    "agent",
    "orchestration",
    "code-generation",
    "harness",
    "proof-carrying",
    "hexagonal-architecture"
  ],
  "author": "Pi Forge Architecture Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Unluckyathecking/pi-forge.git"
  }
}
